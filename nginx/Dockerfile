# Stage 1: Build React SPA
FROM node:20-alpine AS frontend-build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend/ .
RUN npm run build

# Stage 2: Build static multilingual site
FROM node:20-alpine AS static-build
WORKDIR /build
COPY static-src/ ./static-src/
WORKDIR /build/static-src
RUN node build.js

# Stage 3: Nginx final
FROM nginx:alpine
# React SPA
COPY --from=frontend-build /app/dist /usr/share/nginx/html
# Static multilingual site (generated by build.js)
COPY --from=static-build /build/static/ /usr/share/nginx/static
# Shared assets also in /html/ so /shared/ alias works
COPY --from=static-build /build/static/shared/ /usr/share/nginx/html/shared/
# Nginx config (can be overridden by volume mount in dev)
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
